{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://localhost:3000",
    "https://your-production-domain.com"
  ],
  "Jwt": {
    "Issuer": "APMMS",
    "Audience": "APMMS.Client",
    "Key": "[Set in User Secrets]",
    "ExpireMinutes": 30,
    "RefreshTokenExpireDays": 7
  },
  "ConnectionStrings": {
    "DefaultConnection": "[Set in User Secrets]"
  },
  "AdminMaintenance": {
    "RehashKey": "[Set in User Secrets]"
  },
  "Cloudinary": {
    "CloudName": "[Set in User Secrets]",
    "ApiKey": "[Set in User Secrets]",
    "ApiSecret": "[Set in User Secrets]"
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpUsername": "[Set in User Secrets]",
    "SmtpPassword": "[Set in User Secrets]",
    "FromEmail": "[Set in User Secrets]",
    "FromName": "Hệ thống APMMS"
  },
  "AppSettings": {
    "BaseUrl": "https://localhost:7102"
  }
}
