                    <td colspan="3" class="text-center text-muted">
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">Đang tải...</span>
                        </div>
                    </td>
                </tr>
            `;

            fetch(`${API_BASE_URL}/CarOfAutoOwner/user/${currentUser.id}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }
                    return response.json();
                })
                .then(cars => {
                    tbody.innerHTML = '';
                    
                    if (!cars || cars.length === 0) {
                        document.getElementById('carsEmptyMessage').style.display = 'block';
                        tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted">Không có dữ liệu</td></tr>';
                        return;
                    }

                    document.getElementById('carsEmptyMessage').style.display = 'none';
                    
                    // Lọc theo từ khóa tìm kiếm nếu có
                    const searchInput = document.getElementById('carSearchInput');
                    const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
                    let filteredCars = cars;
                    
                    if (searchTerm) {
                        filteredCars = cars.filter(car => {
                            const carName = (car.carName || '').toLowerCase();
                            const carModel = (car.carModel || '').toLowerCase();
                            return carName.includes(searchTerm) || carModel.includes(searchTerm);
                        });
                    }
                    
                    if (filteredCars.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted">Không tìm thấy phương tiện nào</td></tr>';
                        return;
                    }
                    
                    filteredCars.forEach(car => {
                        const row = document.createElement('tr');
                        const createdDate = car.createdDate 
                            ? new Date(car.createdDate).toLocaleDateString('vi-VN', {
                                day: '2-digit',
                                month: '2-digit',
                                year: 'numeric'
                            })
                            : '-';
                        
                        row.innerHTML = `
                            <td><a href="/Users/CarDetail/${car.id}" style="color: #007bff; text-decoration: none; cursor: pointer;">${car.carName || '-'}</a></td>
                            <td>${car.carModel || '-'}</td>
                            <td>${createdDate}</td>
                        `;
                        tbody.appendChild(row);
                    });
                })
                .catch(error => {
                    console.error('Error loading cars:', error);
                    tbody.innerHTML = '<tr><td colspan="3" class="text-center text-danger">Lỗi khi tải danh sách xe: ' + error.message + '</td></tr>';
                    document.getElementById('carsEmptyMessage').style.display = 'none';
                });
        }
        
        // Load vehicle types for dropdown
        function loadVehicleTypes() {
            fetch(`${API_BASE_URL}/VehicleType`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }
                    return response.json();
                })
                .then(vehicleTypes => {
                    const select = document.getElementById('vehicleTypeId');
                    if (select) {
                        select.innerHTML = '<option value="">-- Chọn loại phương tiện --</option>';
                        if (vehicleTypes && Array.isArray(vehicleTypes)) {
                            vehicleTypes.forEach(vt => {
                                const option = document.createElement('option');
                                option.value = vt.id;
                                option.textContent = vt.name;
                                select.appendChild(option);
                            });
                        }
                    }
                })
                .catch(error => {
                    console.error('Error loading vehicle types:', error);
                });
        }
        
        // Kiểm tra trùng (nếu BE hỗ trợ endpoint check-duplicate). Nếu lỗi/404 sẽ bỏ qua để không chặn luồng.
        async function checkCarDuplicate(plate, vin, engine) {
            try {
                const params = new URLSearchParams();
                if (plate) params.append('licensePlate', plate);
                if (vin) params.append('vinNumber', vin);
                if (engine) params.append('engineNumber', engine);

                if (!plate && !vin && !engine) return { success: true, data: {} };

                const controller = new AbortController();
                const timeoutId = setTimeout(() => controller.abort(), 6000);

                const resp = await fetch(`${API_BASE_URL}/CarOfAutoOwner/check-duplicate?${params.toString()}`, {
                    headers: { 'Authorization': `Bearer ${localStorage.getItem('authToken') || localStorage.getItem('token') || ''}` },
                    signal: controller.signal
                });

                clearTimeout(timeoutId);

                if (!resp.ok) {
                    console.warn('Skip duplicate check, status:', resp.status);
                    return { success: true, data: {} };
                }

                const data = await resp.json().catch(() => ({}));
                return data;
            } catch (e) {
                console.warn('Skip duplicate check due to error:', e);
                return { success: true, data: {} };
            }
        }
        
        function validateCarForm() {
            const errors = [];
            const carName = document.getElementById('carName').value.trim();
            const carModel = document.getElementById('carModel').value.trim();
            const vehicleTypeId = document.getElementById('vehicleTypeId').value;
            const carColor = document.getElementById('carColor').value.trim();
            const yearOfManufacture = document.getElementById('yearOfManufacture').value;
            const vinNumber = document.getElementById('vinNumber').value.trim();
            const vehicleEngineNumber = document.getElementById('vehicleEngineNumber').value.trim();
            // Chuẩn hoá biển số: bỏ khoảng trắng/dấu chấm, upper-case
            const licensePlate = document.getElementById('licensePlate').value
                .trim()
                .replace(/\s+/g, '')
                .toUpperCase();

            if (carName.length < 2 || carName.length > 30) {
                errors.push('Tên phương tiện phải từ 2-30 ký tự.');
            }
            if (carModel.length < 1 || carModel.length > 20) {
                errors.push('Model phải từ 1-20 ký tự.');
            }
            if (!vehicleTypeId) {
                errors.push('Vui lòng chọn loại phương tiện.');
            }
            if (carColor.length < 1 || carColor.length > 10) {
                errors.push('Màu xe phải từ 1-10 ký tự.');
            }
            const currentYear = new Date().getFullYear();
            const year = parseInt(yearOfManufacture, 10);
            if (isNaN(year) || year < 1950 || year > currentYear + 1) {
                errors.push(`Năm sản xuất phải từ 1950 đến ${currentYear + 1}.`);
            }
            const vinRegex = /^[A-HJ-NPR-Z0-9]{17}$/;
            if (vinNumber.length !== 17 || !vinRegex.test(vinNumber.toUpperCase())) {
                errors.push('Số khung (VIN) phải đúng 17 ký tự (không chứa I, O, Q).');
            }
            const engineRegex = /^[A-Z0-9\-]{5,20}$/i;
            if (!engineRegex.test(vehicleEngineNumber)) {
                errors.push('Số máy phải gồm 5-20 ký tự chữ số hoặc dấu gạch ngang.');
            }
            // Biển số: bám gần regex BE (30A-12345, 30A-123.45, 59N-12345,...)
            const plateRegex = /^(?:[0-9]{2}[A-Z]-[0-9]{2}\.[0-9]{3}|[0-9]{2}[A-Z]-[0-9]{3}\.[0-9]{2}|[0-9]{2}[A-Z]-?[0-9]{4,5})$/;
            if (!plateRegex.test(licensePlate)) {
                errors.push('Biển số không hợp lệ. Ví dụ: 30A-12345, 30A-123.45, 59N-12345.');
            }

            if (errors.length) {
                showNotification(errors.join('<br>'), 'error');
                return { isValid: false };
            }
            return { isValid: true, licensePlate };
        }

        // Submit add car form
        function submitAddCarForm() {
            if (!currentUser || !currentUser.id) {
                showNotification('Không tìm thấy thông tin người dùng', 'error');
                return;
            }
            
            const form = document.getElementById('addCarForm');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            const validation = validateCarForm();
            if (!validation.isValid) {
                return;
            }
            
            const formData = {
                userId: currentUser.id,
                carName: document.getElementById('carName').value,
                carModel: document.getElementById('carModel').value,
                vehicleTypeId: parseInt(document.getElementById('vehicleTypeId').value),
                color: document.getElementById('carColor').value,
                yearOfManufacture: parseInt(document.getElementById('yearOfManufacture').value),
                vinNumber: document.getElementById('vinNumber').value,
                vehicleEngineNumber: document.getElementById('vehicleEngineNumber').value,
                licensePlate: validation.licensePlate
                // Không gửi branchId vì xe của khách hàng không cần chi nhánh
            };
            
            // Lấy token từ localStorage - thử nhiều key có thể
            let token = localStorage.getItem('authToken') || localStorage.getItem('token');
            
            // Nếu vẫn không có, thử lấy từ userInfo
            if (!token) {
                const userInfo = localStorage.getItem('userInfo');
                if (userInfo) {
                    try {
                        const userInfoObj = JSON.parse(userInfo);
                        token = userInfoObj.token;
                    } catch (e) {
                        console.error('Error parsing userInfo:', e);
                    }
                }
            }
            
            if (!token) {
                showNotification('Bạn cần đăng nhập để thực hiện thao tác này. Vui lòng đăng nhập lại.', 'warning');
                console.error('Token not found in localStorage. Available keys:', Object.keys(localStorage));
                return;
            }
            
            // Show loading state
            const submitBtn = document.getElementById('addCarSubmitBtn');
            if (!submitBtn) {
                showNotification('Không tìm thấy nút submit', 'error');
                return;
            }
            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang thêm...';
            
            // Check duplicates before submit
            const plate = formData.licensePlate;
            const vin = formData.vinNumber;
            const engine = formData.vehicleEngineNumber;
            
            checkCarDuplicate(plate, vin, engine)
                .then(result => {
                    if (result && result.success === false && result.message) {
                        throw new Error(result.message);
                    }
                    if (result && result.data) {
                        const { licensePlateExists, vinNumberExists, engineNumberExists } = result.data;
                        const dupMessages = [];
                        if (licensePlateExists) dupMessages.push('Biển số xe đã tồn tại.');
                        if (vinNumberExists) dupMessages.push('Số khung (VIN) đã tồn tại.');
                        if (engineNumberExists) dupMessages.push('Số máy đã tồn tại.');
                        if (dupMessages.length) {
                            throw new Error(dupMessages.join('<br>'));
                        }
                    }
                    
                    // Timeout guard to avoid stuck spinner
                    const controller = new AbortController();
                    const timeoutId = setTimeout(() => controller.abort(), 10000);

                    return fetch(`${API_BASE_URL}/CarOfAutoOwner`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${token}`
                        },
                        body: JSON.stringify(formData),
                        signal: controller.signal
                    }).finally(() => clearTimeout(timeoutId));
                })
                .then(async response => {
                    // Đọc body một lần, ưu tiên parse JSON
                    let rawText = '';
                    let responseData = {};
                    try {
                        rawText = await response.text();
                        try {
                            responseData = JSON.parse(rawText);
                        } catch {
                            responseData = { message: rawText };
                        }
                    } catch { /* ignore */ }

                    if (!response.ok) {
                        const serverMsg = responseData?.message || responseData?.error || responseData?.title;
                        let errorMessage = serverMsg || 'Đã xảy ra lỗi khi thêm xe.';

                        if (!serverMsg && responseData?.errors) {
                            const firstKey = Object.keys(responseData.errors)[0];
                            if (firstKey) {
                                errorMessage = responseData.errors[firstKey]?.join('<br>') || errorMessage;
                            }
                        }

                        if (response.status === 400 && !serverMsg && !responseData?.errors) {
                            errorMessage = 'Dữ liệu không hợp lệ. Vui lòng kiểm tra: biển số (đúng định dạng), VIN 17 ký tự, số máy 5-20 ký tự.';
                        } else if (response.status === 500 && !serverMsg) {
                            errorMessage = 'Lỗi server. Vui lòng thử lại sau.';
                        }

                        console.error('Add car failed', { status: response.status, body: responseData, rawText });
                        throw new Error(errorMessage);
                    }

                    return responseData;
                })
                .then(data => {
                    showNotification('Thêm xe thành công!', 'success');
                    const modalElement = document.getElementById('addCarModal');
                    if (modalElement) {
                        let modalInstance = bootstrap.Modal.getInstance(modalElement);
                        if (!modalInstance) {
                            modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
                        }
                        if (modalInstance) {
                            modalInstance.hide();
                        }
                    }
                    cleanupModalBackdrop();
                    document.getElementById('addCarForm').reset();
                    loadUserCars();
                })
                .catch(error => {
                    console.error('Error adding car:', error);
                    if (error.name === 'AbortError') {
                        showNotification('Quá thời gian chờ khi thêm xe. Vui lòng thử lại.', 'error');
                    } else {
                        showNotification(error.message || 'Có lỗi xảy ra khi thêm xe.', 'error');
                    }
                })
                .finally(() => {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                });
        }

        function cleanupModalBackdrop() {
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('padding-right');
            document.querySelectorAll('.modal-backdrop').forEach(backdrop => backdrop.remove());
        }
        
        // Reset add car form
        function resetAddCarForm() {
            const form = document.getElementById('addCarForm');
            if (form) {
                form.reset();
            }
        }
    </script>
}
