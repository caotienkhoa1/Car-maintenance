                            const userAvatar = document.getElementById('userAvatar');
                            if (userAvatar) {
                                userAvatar.src = imageDataUrl;
                            }
                        };
                        reader.onerror = function() {
                            showNotification('Có lỗi xảy ra khi đọc file', 'error');
                            e.target.value = '';
                        };
                        reader.readAsDataURL(file);
