                            }
                        }
                    }
                });
            }
        }

        function getUserIdFromUrl() {
            // Try to get from ViewBag first (set by controller)
            const viewBagId = @(ViewBag.UserId ?? 0);
            if (viewBagId && viewBagId > 0) {
                return viewBagId.toString();
            }
            
            // Fallback: extract from URL path
            const path = window.location.pathname;
            const segments = path.split('/').filter(seg => seg && seg.trim() !== '');
            const lastSegment = segments[segments.length - 1];
            
            // Remove any hash fragments or query parameters
            let userId = lastSegment;
            if (userId) {
                // Remove hash fragment
                userId = userId.split('#')[0];
                // Remove query parameters
                userId = userId.split('?')[0];
                // Remove any non-numeric characters at the end (like :1)
                userId = userId.replace(/[^0-9].*$/, '');
            }
            
            // Validate it's a number
            const idNum = parseInt(userId, 10);
            if (isNaN(idNum) || idNum <= 0) {
                console.error('Invalid user ID from URL:', userId);
                return null;
            }
            
            return idNum.toString();
        }

        function loadUserDetails(id) {
            // Validate ID before making request - convert to string first
            const idStr = String(id || '').trim();
            if (!idStr || idStr === '' || isNaN(parseInt(idStr, 10))) {
                console.error('Invalid user ID:', id);
                showError('ID người dùng không hợp lệ');
                return;
            }
            // Use idStr for API call
            id = idStr;
            const token = localStorage.getItem('authToken');
            if (!token) {
                document.getElementById('loadingSpinner').style.display = 'none';
                showError('Vui lòng đăng nhập lại để xem thông tin khách hàng.');
                return;
            }

            fetch(`${API_BASE_URL}/AutoOwner/${id}`, {
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                }
            })
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }
                    return response.json();
                })
                .then(data => {
                    document.getElementById('loadingSpinner').style.display = 'none';
                    
                    // API trả về trực tiếp ResponseDto
                    if (data && data.id) {
                        displayUserDetails(data);
                    } else if (data && data.success && data.data) {
                        displayUserDetails(data.data);
                    } else {
                        showError('Không tìm thấy thông tin người dùng');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    document.getElementById('loadingSpinner').style.display = 'none';
                    showError('Có lỗi xảy ra khi tải thông tin người dùng: ' + error.message);
                });
        }

