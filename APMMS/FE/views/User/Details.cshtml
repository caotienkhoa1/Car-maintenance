                    try {
                        let dob;
                        if (typeof dobValue === 'string') {
                            dob = new Date(dobValue);
                        } else {
                            dob = new Date(dobValue);
                        }
                        if (!isNaN(dob.getTime())) {
                            // Format to YYYY-MM-DD for date input
