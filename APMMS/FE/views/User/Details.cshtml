                            e.target.value = '';
                            return;
                        }
                        
                        // Validate file size (max 5MB)
                        if (file.size > 5 * 1024 * 1024) {
                            showNotification('Kích thước file không được vượt quá 5MB', 'warning');
                            e.target.value = '';
