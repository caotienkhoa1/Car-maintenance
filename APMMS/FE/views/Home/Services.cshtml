@{
    ViewData["Title"] = "Dịch vụ";
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="page-title">Dịch vụ</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb justify-content-center">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang chủ</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Dịch vụ</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</section>

<!-- Services Overview -->
<section class="services-overview py-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center mb-5">
                <h2 class="section-title">Dịch vụ của chúng tôi</h2>
                <p class="section-subtitle">Cung cấp đầy đủ các dịch vụ bảo dưỡng và sửa chữa ô tô chuyên nghiệp</p>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card h-100">
                    <div class="service-icon">
                        <i class="fas fa-oil-can"></i>
                    </div>
                    <h4 class="service-title">Thay dầu & Bảo dưỡng định kỳ</h4>
                    <p class="service-desc">Thay dầu động cơ, lọc dầu, lọc gió và kiểm tra tổng quát xe theo lịch trình định kỳ.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check"></i> Thay dầu chính hãng</li>
                        <li><i class="fas fa-check"></i> Kiểm tra 50+ hạng mục</li>
                        <li><i class="fas fa-check"></i> Bảo hành dịch vụ</li>
                    </ul>
                    <a href="#" class="btn btn-outline-primary">Tìm hiểu thêm</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card h-100">
                    <div class="service-icon">
                        <i class="fas fa-car-crash"></i>
                    </div>
                    <h4 class="service-title">Sửa chữa động cơ</h4>
                    <p class="service-desc">Chẩn đoán và sửa chữa các vấn đề về động cơ, hệ thống truyền động.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check"></i> Chẩn đoán chính xác</li>
                        <li><i class="fas fa-check"></i> Sửa chữa chuyên sâu</li>
                        <li><i class="fas fa-check"></i> Thay thế phụ tùng</li>
                    </ul>
                    <a href="#" class="btn btn-outline-primary">Tìm hiểu thêm</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card h-100">
                    <div class="service-icon">
                        <i class="fas fa-car-battery"></i>
                    </div>
                    <h4 class="service-title">Hệ thống điện</h4>
                    <p class="service-desc">Kiểm tra, sửa chữa và thay thế các thành phần hệ thống điện của xe.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check"></i> Ắc quy & Máy phát điện</li>
                        <li><i class="fas fa-check"></i> Hệ thống đèn chiếu sáng</li>
                        <li><i class="fas fa-check"></i> Cảm biến & ECU</li>
                    </ul>
                    <a href="#" class="btn btn-outline-primary">Tìm hiểu thêm</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card h-100">
                    <div class="service-icon">
                        <i class="fas fa-snowflake"></i>
                    </div>
                    <h4 class="service-title">Hệ thống điều hòa</h4>
                    <p class="service-desc">Bảo dưỡng, sửa chữa và nạp gas điều hòa ô tô chuyên nghiệp.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check"></i> Vệ sinh dàn lạnh</li>
                        <li><i class="fas fa-check"></i> Nạp gas chuẩn</li>
                        <li><i class="fas fa-check"></i> Kiểm tra rò rỉ</li>
                    </ul>
                    <a href="#" class="btn btn-outline-primary">Tìm hiểu thêm</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card h-100">
                    <div class="service-icon">
                        <i class="fas fa-tire"></i>
                    </div>
                    <h4 class="service-title">Lốp & Bánh xe</h4>
                    <p class="service-desc">Cân bằng động, căn chỉnh thước lái, thay lốp và vá lốp chuyên nghiệp.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check"></i> Cân bằng lốp</li>
                        <li><i class="fas fa-check"></i> Căn chỉnh góc đặt bánh</li>
                        <li><i class="fas fa-check"></i> Thay lốp các loại</li>
                    </ul>
                    <a href="#" class="btn btn-outline-primary">Tìm hiểu thêm</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card h-100">
                    <div class="service-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h4 class="service-title">Kiểm tra an toàn</h4>
                    <p class="service-desc">Kiểm tra toàn diện hệ thống phanh, hệ thống treo và an toàn xe.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check"></i> Kiểm tra phanh ABS</li>
                        <li><i class="fas fa-check"></i> Hệ thống treo</li>
                        <li><i class="fas fa-check"></i> Túi khí & An toàn</li>
                    </ul>
                    <a href="#" class="btn btn-outline-primary">Tìm hiểu thêm</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Service Packages -->
<section class="service-packages py-5 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center mb-5">
                <h2 class="section-title">Gói dịch vụ</h2>
                <p class="section-subtitle">Lựa chọn gói dịch vụ phù hợp với nhu cầu của bạn</p>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-4 mb-4">
                <div class="package-card">
                    <div class="package-header">
                        <h4>Cơ bản</h4>
                        <div class="package-price">
                            <span class="price">500.000đ</span>
                            <span class="period">/lần</span>
                        </div>
                    </div>
                    <div class="package-body">
                        <ul class="package-features">
                            <li><i class="fas fa-check"></i> Thay dầu động cơ</li>
                            <li><i class="fas fa-check"></i> Thay lọc dầu</li>
                            <li><i class="fas fa-check"></i> Kiểm tra tổng quát</li>
                            <li><i class="fas fa-check"></i> Vệ sinh cơ bản</li>
                            <li class="disabled"><i class="fas fa-times"></i> Thay lọc gió</li>
                            <li class="disabled"><i class="fas fa-times"></i> Kiểm tra phanh</li>
                        </ul>
                        <a href="@Url.Action("Index", "ServicePackage")" class="btn btn-outline-primary w-100">Xem chi tiết</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 mb-4">
                <div class="package-card popular">
                    <div class="package-badge">Phổ biến</div>
                    <div class="package-header">
                        <h4>Tiêu chuẩn</h4>
                        <div class="package-price">
                            <span class="price">1.200.000đ</span>
                            <span class="period">/lần</span>
                        </div>
                    </div>
                    <div class="package-body">
                        <ul class="package-features">
                            <li><i class="fas fa-check"></i> Tất cả dịch vụ Cơ bản</li>
                            <li><i class="fas fa-check"></i> Thay lọc gió</li>
                            <li><i class="fas fa-check"></i> Thay lọc cabin</li>
                            <li><i class="fas fa-check"></i> Kiểm tra phanh</li>
                            <li><i class="fas fa-check"></i> Kiểm tra ắc quy</li>
                            <li class="disabled"><i class="fas fa-times"></i> Vệ sinh hệ thống</li>
                        </ul>
                        <a href="@Url.Action("Index", "ServicePackage")" class="btn btn-primary w-100">Xem chi tiết</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 mb-4">
                <div class="package-card">
                    <div class="package-header">
                        <h4>Cao cấp</h4>
                        <div class="package-price">
                            <span class="price">2.500.000đ</span>
                            <span class="period">/lần</span>
                        </div>
                    </div>
                    <div class="package-body">
                        <ul class="package-features">
                            <li><i class="fas fa-check"></i> Tất cả dịch vụ Tiêu chuẩn</li>
                            <li><i class="fas fa-check"></i> Vệ sinh buồng đốt</li>
                            <li><i class="fas fa-check"></i> Vệ sinh kim phun</li>
                            <li><i class="fas fa-check"></i> Cân bằng động</li>
                            <li><i class="fas fa-check"></i> Kiểm tra điện tử</li>
                            <li><i class="fas fa-check"></i> Bảo hành 6 tháng</li>
                        </ul>
                        <a href="@Url.Action("Index", "ServicePackage")" class="btn btn-outline-primary w-100">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section py-5">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="cta-box text-center">
                    <h3>Bạn cần tư vấn dịch vụ?</h3>
                    <p>Đội ngũ tư vấn viên của chúng tôi sẵn sàng hỗ trợ bạn 24/7</p>
                    <div class="cta-buttons">
                        <a href="tel:190011089" class="btn btn-light btn-lg me-3">
                            <i class="fas fa-phone"></i> 1900 110 89
                        </a>
                        <a href="@Url.Action("Contact", "Home")" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-envelope"></i> Liên hệ ngay
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.page-header {
    background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
    padding: 60px 0;
    color: white;
}

.page-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 10px;
}

.breadcrumb {
    background: transparent;
}

.breadcrumb a {
    color: rgba(255,255,255,0.8);
    text-decoration: none;
}

.breadcrumb a:hover {
    color: white;
}

.breadcrumb-item.active {
    color: white;
}

.section-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 15px;
}

.section-subtitle {
    color: #6c757d;
    font-size: 1.1rem;
}

.service-card {
    background: white;
    border-radius: 15px;
    padding: 30px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    transition: transform 0.3s, box-shadow 0.3s;
}

.service-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.1);
}

.service-icon {
    width: 70px;
    height: 70px;
    background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
}

.service-icon i {
    font-size: 2rem;
    color: white;
}

.service-title {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 15px;
}

.service-desc {
    color: #6c757d;
    margin-bottom: 20px;
}

.service-features {
    list-style: none;
    padding: 0;
    margin-bottom: 20px;
}

.service-features li {
    padding: 5px 0;
    color: #495057;
}

.service-features li i {
    color: #28a745;
    margin-right: 8px;
}

.package-card {
    background: white;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    position: relative;
    transition: transform 0.3s;
}

.package-card:hover {
    transform: translateY(-10px);
}

.package-card.popular {
    border: 2px solid #6366F1;
    transform: scale(1.05);
}

.package-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #6366F1;
    color: white;
    padding: 5px 15px;
    font-size: 0.8rem;
    border-bottom-left-radius: 10px;
}

.package-header {
    background: #f8f9fa;
    padding: 30px;
    text-align: center;
}

.package-header h4 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 15px;
}

.package-price {
    margin-top: 10px;
}

.package-price .price {
    font-size: 2.5rem;
    font-weight: 700;
    color: #6366F1;
}

.package-price .period {
    color: #6c757d;
}

.package-body {
    padding: 30px;
}

.package-features {
    list-style: none;
    padding: 0;
    margin-bottom: 30px;
}

.package-features li {
    padding: 10px 0;
    border-bottom: 1px solid #f0f0f0;
}

.package-features li:last-child {
    border-bottom: none;
}

.package-features li i {
    margin-right: 10px;
}

.package-features li i.fa-check {
    color: #28a745;
}

.package-features li i.fa-times {
    color: #dc3545;
}

.package-features li.disabled {
    color: #adb5bd;
}

.cta-section {
    background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
}

.cta-box {
    color: white;
    padding: 40px;
}

.cta-box h3 {
    font-size: 2rem;
    margin-bottom: 15px;
}

.cta-box p {
    font-size: 1.1rem;
    margin-bottom: 30px;
    opacity: 0.9;
}

.cta-buttons .btn {
    padding: 12px 30px;
}

@@media (max-width: 991px) {
    .package-card.popular {
        transform: scale(1);
    }
}
</style>
